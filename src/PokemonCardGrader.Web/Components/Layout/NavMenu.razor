@implements IDisposable

@inject NavigationManager NavigationManager

<aside class="sidebar">
    <div class="brand">
        <div class="brand-mark">C</div>
        <div class="brand-name">
            Calibra
            <small>Card Grading Studio</small>
        </div>
    </div>

    <AuthorizeView>
        <Authorized>
            <div class="nav-label">Workspace</div>

            <NavLink class="nav-item" href="dashboard" Match="NavLinkMatch.All">
                <svg viewBox="0 0 24 24"><path d="M3 10.5 12 3l9 7.5"/><path d="M5 9.5V20h14V9.5"/></svg>
                <span>Overview</span>
            </NavLink>

            <NavLink class="nav-item" href="collection" Match="NavLinkMatch.Prefix">
                <svg viewBox="0 0 24 24"><rect x="4" y="4" width="7" height="7" rx="1.5"/><rect x="13" y="4" width="7" height="7" rx="1.5"/><rect x="4" y="13" width="7" height="7" rx="1.5"/><rect x="13" y="13" width="7" height="7" rx="1.5"/></svg>
                <span>Collection</span>
            </NavLink>

            <NavLink class="nav-item" href="submissions" Match="NavLinkMatch.Prefix">
                <svg viewBox="0 0 24 24"><rect x="4" y="4" width="16" height="16" rx="2"/><path d="M8 4v16M4 8h16"/></svg>
                <span>Submissions</span>
            </NavLink>

            <NavLink class="nav-item" href="submissions/new" Match="NavLinkMatch.All">
                <svg viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
                <span>New submission</span>
            </NavLink>

            <div class="nav-label">Library</div>

            <NavLink class="nav-item" href="cards/search" Match="NavLinkMatch.Prefix">
                <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
                <span>Card catalog</span>
            </NavLink>

            <NavLink class="nav-item" href="graded" Match="NavLinkMatch.Prefix">
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
                <span>Graded archive</span>
            </NavLink>

            <div class="sidebar-footer">
                <div class="avatar">@(context.User.Identity?.Name?.Substring(0, 1).ToUpper())</div>
                <div class="who">
                    @context.User.Identity?.Name
                    <small>
                        <a href="Account/Manage">Account settings</a>
                    </small>
                </div>
                <form action="Account/Logout" method="post" style="margin-left:auto">
                    <AntiforgeryToken />
                    <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                    <button type="submit" class="btn-ghost" title="Logout" style="padding:4px 8px;border:none;background:none;cursor:pointer;color:var(--ink-4)">
                        <svg viewBox="0 0 24 24" style="width:15px;height:15px;stroke:currentColor;stroke-width:1.5;fill:none">
                            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9"/>
                        </svg>
                    </button>
                </form>
            </div>
        </Authorized>
        <NotAuthorized>
            <div class="nav-label">Account</div>

            <NavLink class="nav-item" href="Account/Login" Match="NavLinkMatch.All">
                <svg viewBox="0 0 24 24"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4M10 17l5-5-5-5M15 12H3"/></svg>
                <span>Sign in</span>
            </NavLink>

            <NavLink class="nav-item" href="Account/Register" Match="NavLinkMatch.All">
                <svg viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                <span>Register</span>
            </NavLink>
        </NotAuthorized>
    </AuthorizeView>
</aside>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
