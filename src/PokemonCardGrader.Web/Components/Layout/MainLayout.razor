@inherits LayoutComponentBase

<div class="app">
    <NavMenu />

    <main class="main-area">
        <div class="topbar">
            <div class="crumbs">
                <strong>Calibra</strong>
            </div>
            <div class="grow"></div>
            <div class="search">
                <svg viewBox="0 0 24 24" style="width:13px;height:13px;stroke:currentColor;stroke-width:1.5;fill:none;color:var(--ink-4)">
                    <circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/>
                </svg>
                <input placeholder="Search cards, sets, submissions..." />
            </div>
        </div>

        <div class="main-content">
            @Body
        </div>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">&#x1f5d9;</span>
</div>
