@* Drag-and-drop image uploader with preview *@

@inject ImageProcessingService ImageProcessingService
@inject PokemonCardGrader.Application.Interfaces.IImageStorageService ImageStorageService

<div class="image-uploader">
    <div class="border border-dashed rounded p-4 text-center @(_isDragOver ? "bg-light border-primary" : "")"
         @ondragover="HandleDragOver"
         @ondragover:preventDefault
         @ondragleave="HandleDragLeave"
         @ondrop="HandleDrop"
         @ondrop:preventDefault>

        @if (_previewUrl is not null)
        {
            <img src="@_previewUrl" alt="Card preview" class="img-fluid mb-2" style="max-height: 300px;" />
            <br />
            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="ClearImage">Remove</button>
        }
        else
        {
            <div style="margin-bottom:12px">
                <p class="mb-2">Drag & drop a card image here, or click to browse</p>
                <div style="display:flex;flex-wrap:wrap;gap:12px;justify-content:center;margin-bottom:10px">
                    <div class="capture-tip">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
                        </svg>
                        <span>Even lighting, no shadows</span>
                    </div>
                    <div class="capture-tip">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="3" width="18" height="18" rx="2"/><rect x="7" y="7" width="10" height="10" rx="1" stroke-dasharray="3 2"/>
                        </svg>
                        <span>Card fills ~80% of frame</span>
                    </div>
                    <div class="capture-tip">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"/><line x1="4" y1="4" x2="20" y2="20"/>
                        </svg>
                        <span>No glare or reflections</span>
                    </div>
                    <div class="capture-tip">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/>
                        </svg>
                        <span>Flat surface, camera parallel</span>
                    </div>
                </div>
            </div>
            <InputFile OnChange="HandleFileSelected" accept="image/*" class="form-control" />
        }
    </div>

    @if (_isUploading)
    {
        <div class="mt-2">
            <div class="progress">
                <div class="progress-bar progress-bar-striped progress-bar-animated" style="width: 100%">
                    Uploading & analyzing...
                </div>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger mt-2">@_errorMessage</div>
    }

    @if (_uploadComplete)
    {
        <div class="alert alert-success mt-2">Image uploaded and queued for analysis.</div>
    }
</div>

@code {
    [Parameter] public Guid SubmissionId { get; set; }
    [Parameter] public string UserId { get; set; } = string.Empty;
    [Parameter] public ImageType ImageType { get; set; } = ImageType.Front;
    [Parameter] public EventCallback<PokemonCardGrader.Domain.Entities.CardImage> OnUploadComplete { get; set; }
    [Parameter] public EventCallback<string> OnLocalImageReady { get; set; }

    private bool _isDragOver;
    private bool _isUploading;
    private bool _uploadComplete;
    private string? _previewUrl;
    private string? _errorMessage;

    private void HandleDragOver() => _isDragOver = true;
    private void HandleDragLeave() => _isDragOver = false;

    private void HandleDrop()
    {
        _isDragOver = false;
        // File handling happens via InputFile
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        _errorMessage = null;
        _uploadComplete = false;
        var file = e.File;

        if (file.Size > 10 * 1024 * 1024)
        {
            _errorMessage = "File size must be less than 10 MB.";
            return;
        }

        if (!file.ContentType.StartsWith("image/"))
        {
            _errorMessage = "Only image files are accepted.";
            return;
        }

        // Read as data URL immediately for local preview / overlay
        if (OnLocalImageReady.HasDelegate)
        {
            try
            {
                await using var previewStream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
                using var ms = new MemoryStream();
                await previewStream.CopyToAsync(ms);
                var base64 = Convert.ToBase64String(ms.ToArray());
                var dataUrl = $"data:{file.ContentType};base64,{base64}";
                await OnLocalImageReady.InvokeAsync(dataUrl);
            }
            catch (Exception ex)
            {
                // Non-fatal: overlay just won't appear until upload completes
                System.Diagnostics.Debug.WriteLine($"Local preview failed: {ex.Message}");
            }
        }

        _isUploading = true;

        try
        {
            await using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            var cardImage = await ImageProcessingService.UploadAndEnqueueAsync(
                SubmissionId, UserId, stream, file.Name, ImageType, file.Size);

            _previewUrl = ImageStorageService.GetImageUrl(cardImage.StoragePath);
            _uploadComplete = true;
            await OnUploadComplete.InvokeAsync(cardImage);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Upload failed: {ex.Message}";
        }
        finally
        {
            _isUploading = false;
        }
    }

    private void ClearImage()
    {
        _previewUrl = null;
        _uploadComplete = false;
    }
}
