@using PokemonCardGrader.Domain.ValueObjects
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject ILogger<ImageOverlayEditor> Logger

@*
    Line-guide centering editor.

    Shows the original photo and lets the user place 8 OUTER (cyan) and 8
    INNER (amber) endpoints to define the four card edges and four artwork
    edges. Centering percentages are computed live in JS as the user drags;
    on Confirm we snapshot the guide state and ship it to the parent via
    OnCorrectionSubmitted as a single UserCorrection payload.

    There is no auto-save during drag. The reviews of competing apps that
    we surveyed all complained about chatty roundtrips and reset-on-touch
    bugs that come from updating server state on every pointermove. The
    explicit Confirm button keeps the contract clean: server only sees the
    final state.
*@

<div class="overlay-editor" style="display:flex;flex-direction:column;gap:8px">
    <div class="canvas-wrap"
         style="position:relative;width:100%;aspect-ratio:5/7;background:#0f172a;border:1px solid var(--ink-5);border-radius:8px;overflow:hidden">
        @* The hidden <img> is the canvas's source bitmap. Hidden via display:none
           rather than visibility:hidden so it contributes no layout box. *@
        <img id="@ImageElementId" src="@(LocalImageDataUrl ?? ImageUrl)"
             alt="" style="display:none" crossorigin="anonymous" />
        <canvas id="@CanvasElementId"
                style="position:absolute;inset:0;width:100%;height:100%;cursor:crosshair"></canvas>
    </div>

    <div class="readout"
         style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;font-family:ui-monospace,monospace;font-size:13px">
        <span style="color:var(--ink-3)">L/R</span>
        <span style="font-weight:600;color:@LeftRightColor">@_lrPercent.ToString("F1")/@((100 - _lrPercent).ToString("F1"))</span>
        <span style="color:var(--ink-4)">·</span>
        <span style="color:var(--ink-3)">T/B</span>
        <span style="font-weight:600;color:@TopBottomColor">@_tbPercent.ToString("F1")/@((100 - _tbPercent).ToString("F1"))</span>
        <span style="color:var(--ink-4)">·</span>
        <span style="color:@WorstColor;font-weight:600">@WorstSummary</span>

        <span style="margin-left:auto;display:flex;gap:8px">
            @if (!ImmediateMode)
            {
                <button type="button" class="btn-secondary" @onclick="ResetGuides" disabled="@_busy">
                    Reset
                </button>
                <button type="button" class="btn-primary" @onclick="ConfirmAsync" disabled="@_busy">
                    @(_busy ? "Saving…" : "Confirm")
                </button>
            }
        </span>
    </div>

    <div style="font-size:11px;color:var(--ink-4);line-height:1.45">
        Drag the <span style="color:#22d3ee;font-weight:600">cyan</span> handles to mark the OUTER card edge,
        and the <span style="color:#f59e0b;font-weight:600">amber</span> handles to mark the INNER artwork
        border. Each edge has two endpoints — slight tilt is fine, the math handles it.
    </div>

    @if (_aspectRatioStatus is "unusual" or "wrong")
    {
        @* Advisory only — never blocks Confirm. *@
        <div style="font-size:11px;color:#f59e0b;display:flex;gap:6px;align-items:center;line-height:1.4">
            <span style="font-weight:600">⚠</span>
            <span>
                @if (_aspectRatioStatus == "wrong")
                {
                    <span>The outer guide doesn't look card-shaped — double-check you've placed the cyan handles on the actual card edges.</span>
                }
                else
                {
                    <span>The outer guide aspect ratio is unusual for a Pokémon card. Worth a quick visual check before confirming.</span>
                }
            </span>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public string ImageUrl { get; set; } = string.Empty;
    [Parameter] public string? LocalImageDataUrl { get; set; }
    [Parameter] public AnalysisOverlay? Overlay { get; set; }
    [Parameter] public Guid CardImageId { get; set; }
    [Parameter] public bool ImmediateMode { get; set; }
    [Parameter] public EventCallback<UserCorrection> OnCorrectionSubmitted { get; set; }

    // Stable per-instance ids.
    private readonly string _instanceId = Guid.NewGuid().ToString("N")[..8];
    private string CanvasElementId => $"co-canvas-{_instanceId}";
    private string ImageElementId => $"co-image-{_instanceId}";

    private DotNetObjectReference<ImageOverlayEditor>? _selfRef;
    private bool _initialised;
    private bool _busy;

    /// <summary>
    /// Reference of the last overlay we pushed to JS. Used to skip the JS
    /// round-trip when the parent re-renders but Overlay didn't change.
    /// </summary>
    private AnalysisOverlay? _lastPushedOverlay;

    // Live readout
    private double _lrPercent = 50.0;
    private double _tbPercent = 50.0;
    private string _aspectRatioStatus = "ok";

    private string LeftRightColor => GradeTierColor(_lrPercent);
    private string TopBottomColor => GradeTierColor(_tbPercent);
    private string WorstColor => GradeTierColor(Math.Max(_lrPercent, _tbPercent));

    /// <summary>Worst-axis summary, rendered as the high-level grade tier.</summary>
    private string WorstSummary
    {
        get
        {
            var worst = Math.Max(_lrPercent, _tbPercent);
            return worst switch
            {
                <= 55.0 => "PSA 10 centering range",
                <= 60.0 => "PSA 9 centering range",
                <= 65.0 => "PSA 8 centering range",
                _       => "Below PSA 8 centering"
            };
        }
    }

    private static string GradeTierColor(double worstPct) => worstPct switch
    {
        <= 55.0 => "#10b981", // green
        <= 60.0 => "#eab308", // yellow
        <= 65.0 => "#f97316", // orange
        _       => "#ef4444"  // red
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
            _initialised = await JS.InvokeAsync<bool>(
                "cardOverlay.init", CanvasElementId, ImageElementId, _selfRef);

            if (_initialised && Overlay is not null)
            {
                await PushOverlayToJsAsync();
                _lastPushedOverlay = Overlay;
            }
        }
        else if (_initialised && !ReferenceEquals(_lastPushedOverlay, Overlay))
        {
            await PushOverlayToJsAsync();
            _lastPushedOverlay = Overlay;
        }
    }

    private async Task PushOverlayToJsAsync()
    {
        if (Overlay is null
            || Overlay.OuterGuides.Count != 8
            || Overlay.InnerGuides.Count != 8) return;

        var outer = Overlay.OuterGuides.Select(p => new { x = p.X, y = p.Y }).ToArray();
        var inner = Overlay.InnerGuides.Select(p => new { x = p.X, y = p.Y }).ToArray();
        await JS.InvokeVoidAsync("cardOverlay.setOverlay", CanvasElementId, outer, inner);

        _lrPercent = Overlay.LeftRightCenteringPercent;
        _tbPercent = Overlay.TopBottomCenteringPercent;
        StateHasChanged();
    }

    /// <summary>Called from JS on every drag update with the live centering values.</summary>
    [JSInvokable]
    public Task OnOverlayChanged(double lrPercent, double tbPercent, string aspectRatioStatus)
    {
        _lrPercent = lrPercent;
        _tbPercent = tbPercent;
        _aspectRatioStatus = aspectRatioStatus ?? "ok";
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task ResetGuides()
    {
        if (Overlay is not null)
        {
            await PushOverlayToJsAsync();
        }
        else
        {
            await JS.InvokeVoidAsync("cardOverlay.setOverlay", CanvasElementId, null, null);
        }
    }

    private async Task ConfirmAsync()
    {
        if (_busy || CardImageId == Guid.Empty) return;
        _busy = true;
        StateHasChanged();

        try
        {
            var snap = await JS.InvokeAsync<OverlaySnapshot?>("cardOverlay.snapshot", CanvasElementId);
            if (snap is null
                || snap.OuterGuides is null || snap.OuterGuides.Length != 8
                || snap.InnerGuides is null || snap.InnerGuides.Length != 8)
            {
                Logger.LogWarning(
                    "ConfirmAsync: invalid snapshot for image {ImageId} (counts {Outer}/{Inner})",
                    CardImageId, snap?.OuterGuides?.Length ?? -1, snap?.InnerGuides?.Length ?? -1);
                return;
            }

            var correction = new UserCorrection
            {
                CardImageId = CardImageId,
                OuterGuides = snap.OuterGuides.Select(p => new NormalizedPoint { X = p.X, Y = p.Y }).ToList(),
                InnerGuides = snap.InnerGuides.Select(p => new NormalizedPoint { X = p.X, Y = p.Y }).ToList(),
                LeftRightCenteringPercent = snap.LeftRightPercent,
                TopBottomCenteringPercent = snap.TopBottomPercent
            };

            Logger.LogInformation(
                "ImageOverlayEditor.Confirm: image={ImageId} L/R={LR:F1}% T/B={TB:F1}%",
                CardImageId, snap.LeftRightPercent, snap.TopBottomPercent);

            await OnCorrectionSubmitted.InvokeAsync(correction);
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_initialised)
            {
                await JS.InvokeVoidAsync("cardOverlay.dispose", CanvasElementId);
            }
        }
        catch (JSDisconnectedException) { /* circuit gone, nothing to clean up */ }
        catch (Exception ex) { Logger.LogDebug(ex, "Error during overlay editor dispose"); }

        _selfRef?.Dispose();
        _selfRef = null;
    }

    /// <summary>
    /// JS-snapshot DTO. Property names match cardOverlay.snapshot()'s
    /// camelCase JSON keys.
    /// </summary>
    private sealed class OverlaySnapshot
    {
        public OverlayPoint[]? OuterGuides { get; set; }
        public OverlayPoint[]? InnerGuides { get; set; }
        public double LeftRightPercent { get; set; }
        public double TopBottomPercent { get; set; }
        public string? AspectRatioStatus { get; set; }
    }

    private sealed class OverlayPoint
    {
        public double X { get; set; }
        public double Y { get; set; }
    }
}
