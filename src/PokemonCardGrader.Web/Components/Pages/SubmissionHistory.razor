@page "/submissions"
@rendermode InteractiveServer
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using PokemonCardGrader.Application.DTOs
@using PokemonCardGrader.Application.Services
@inject CardSubmissionService CardSubmissionService
@inject NavigationManager NavigationManager

<PageTitle>Submissions - Calibra</PageTitle>

<div style="display:flex;align-items:flex-end;margin-bottom:24px">
    <div>
        <h1 class="display">Submissions</h1>
        <p class="page-sub" style="margin-bottom:0">All your card submissions in one place.</p>
    </div>
    <div style="margin-left:auto;display:flex;gap:8px">
        <a href="submissions/new" class="btn btn-primary">
            <svg viewBox="0 0 24 24" style="width:14px;height:14px;stroke:currentColor;stroke-width:1.5;fill:none;vertical-align:middle;margin-right:4px">
                <path d="M12 5v14M5 12h14"/>
            </svg>
            New submission
        </a>
    </div>
</div>

@if (_errorMessage is not null)
{
    <div class="alert-box danger">@_errorMessage</div>
}
else if (_isLoading)
{
    <p class="page-sub">Loading submissions...</p>
}
else if (_submissions.Count == 0)
{
    <div class="surface" style="text-align:center;padding:60px 20px">
        <p style="color:var(--ink-3);font-size:14px;margin-bottom:16px">You don't have any submissions yet.</p>
        <a href="cards/search" class="btn btn-primary">Search for a card</a>
    </div>
}
else
{
    <div class="surface">
        <table class="clean">
            <thead>
                <tr>
                    <th>Card</th>
                    <th>Set</th>
                    <th>Submitted</th>
                    <th>Top estimate</th>
                    <th>Actual</th>
                    <th style="width:40px"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var sub in _submissions)
                {
                    var topEstimate = sub.Estimates
                        .OrderByDescending(e => e.Confidence)
                        .FirstOrDefault();

                    <tr @onclick="() => NavigateToSubmission(sub.Id)">
                        <td>
                            <div style="display:flex;gap:12px;align-items:center">
                                <div>
                                    <div style="font-weight:500">@sub.CardName</div>
                                    <div class="mono" style="font-size:10.5px;color:var(--ink-4)">#@sub.Number</div>
                                </div>
                            </div>
                        </td>
                        <td><span style="font-size:12px">@sub.SetName</span></td>
                        <td><span class="mono" style="font-size:12px;color:var(--ink-3)">@sub.CreatedAt.LocalDateTime.ToString("MMM dd, yyyy")</span></td>
                        <td>
                            @if (topEstimate is not null)
                            {
                                <div style="display:flex;align-items:center;gap:8px">
                                    <span class="mono" style="font-size:11px;color:var(--ink-3)">@topEstimate.Company</span>
                                    <span style="font-family:var(--sans);font-weight:500;font-size:16px;letter-spacing:-0.02em">@topEstimate.PredictedGrade.ToString("F1")</span>
                                    <span class="chip" style="font-size:10px">@(Math.Round(topEstimate.Confidence * 100))%</span>
                                </div>
                            }
                            else
                            {
                                <span style="color:var(--ink-4);font-size:12px">Pending</span>
                            }
                        </td>
                        <td>
                            @if (sub.ActualResult is not null)
                            {
                                <span class="chip sage dot">@sub.ActualResult.Company @sub.ActualResult.ActualGrade</span>
                            }
                            else
                            {
                                <span style="color:var(--ink-4);font-size:12px">—</span>
                            }
                        </td>
                        <td>
                            <svg viewBox="0 0 24 24" style="width:14px;height:14px;stroke:currentColor;stroke-width:1.5;fill:none;color:var(--ink-4)">
                                <path d="m9 6 6 6-6 6"/>
                            </svg>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* Pagination *@
    @if (_hasMorePages || _currentPage > 1)
    {
        <div style="display:flex;justify-content:center;gap:8px;margin-top:24px">
            <button class="btn btn-ghost" disabled="@(_currentPage <= 1)" @onclick="PreviousPageAsync">Previous</button>
            <span class="mono" style="padding:8px 12px;font-size:12px;color:var(--ink-3)">Page @_currentPage</span>
            <button class="btn btn-ghost" disabled="@(!_hasMorePages)" @onclick="NextPageAsync">Next</button>
        </div>
    }
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthState { get; set; } = null!;

    private List<CardSubmissionDto> _submissions = [];
    private bool _isLoading = true;
    private string? _errorMessage;
    private int _currentPage = 1;
    private bool _hasMorePages;
    private const int PageSize = 20;

    protected override async Task OnInitializedAsync()
    {
        await LoadSubmissionsAsync();
    }

    private async Task LoadSubmissionsAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var user = (await AuthState).User;
            var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            if (string.IsNullOrEmpty(userId))
            {
                _errorMessage = "Unable to identify the current user.";
                return;
            }

            var submissions = await CardSubmissionService.GetUserSubmissionsAsync(
                userId, _currentPage, PageSize);

            _submissions = submissions
                .Select(CardSubmissionService.MapToDto)
                .ToList();

            _hasMorePages = submissions.Count == PageSize;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load submissions: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task PreviousPageAsync()
    {
        if (_currentPage > 1)
        {
            _currentPage--;
            await LoadSubmissionsAsync();
        }
    }

    private async Task NextPageAsync()
    {
        if (_hasMorePages)
        {
            _currentPage++;
            await LoadSubmissionsAsync();
        }
    }

    private void NavigateToSubmission(Guid id)
    {
        NavigationManager.NavigateTo($"submissions/{id}");
    }
}
